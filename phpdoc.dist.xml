<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor
    configVersion="3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://www.phpdoc.org/changes/namespaces/phpdoc"
    xsi:noNamespaceSchemaLocation="https://docs.phpdoc.org/latest/phpdoc.xsd"
>
    <title>Tendejón Azael - Documentación del Sistema</title>

    <paths>
        <output>docs/api</output>
        <cache>/tmp/phpdoc-cache</cache>
    </paths>

    <version number="1.0.0">
        <api>
            <source dsn=".">
                <path>app</path>
                <path>database/seeders</path>
                <path>database/factories</path>
                <path>routes</path>
            </source>
            <ignore>
                <path>vendor/**/*</path>
                <path>storage/**/*</path>
                <path>bootstrap/cache/**/*</path>
            </ignore>
            <extensions>
                <extension>php</extension>
            </extensions>
            <visibility>public</visibility>
            <visibility>protected</visibility>
            <default-package-name>TendejonAzael</default-package-name>
        </api>
    </version>

    <template name="default" />
</phpdocumentor>
